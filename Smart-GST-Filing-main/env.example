# Auth0 Configuration
AUTH0_SECRET='replace-with-long-random-secret'
AUTH0_BASE_URL='https://your-frontend-domain.vercel.app'
AUTH0_ISSUER_BASE_URL='https://your-auth0-tenant.us.auth0.com'
AUTH0_CLIENT_ID='your-auth0-client-id'
AUTH0_CLIENT_SECRET='your-auth0-client-secret'

# Admin(s) allowed for admin dashboard (comma-separated)
ADMIN_EMAILS='admin@example.com'

# GST Assistant AI Provider (Server-side)
# Preferred option 1: Gemini
GOOGLE_API_KEY='your-google-ai-api-key'
GEMINI_MODEL='gemini-2.5-pro'
GEMINI_TEMPERATURE='0.15'
GEMINI_MAX_OUTPUT_TOKENS='1000'

# Backend API + Razorpay Checkout
NEXT_PUBLIC_API_URL='https://your-backend-domain'
NEXT_PUBLIC_RAZORPAY_KEY_ID='rzp_test_xxxxxxxxxx'