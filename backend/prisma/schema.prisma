// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GstFilingType {
  GSTR1
  GSTR3B
  GSTR9
}

enum GstFilingStatus {
  draft
  validated
  calculated
  filed
  submitted
}

enum GstPaymentStatus {
  pending
  paid
  failed
}

model Business {
  id                  Int      @id @default(autoincrement())
  userId              String
  businessName        String
  businessType        String   // Proprietorship, Private Limited, LLP, Partnership
  natureOfBusiness    String?
  pan                 String
  gstin               String   @unique
  state               String
  city                String
  pincode             String
  address             String?
  contactMobile       String
  contactEmail        String?
  signatoryName       String
  signatoryMobile     String
  panCardUrl          String?
  gstCertificateUrl   String?
  businessLicenseUrl  String?
  isActive            Boolean  @default(true)
  turnover            Decimal  @default(0) @db.Decimal(15, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId])
  @@index([gstin])
}

model Clients {
  id          Int      @id @default(autoincrement())
  userId      String
  name        String
  legalName   String?
  gstin       String
  phoneNumber String
  email       String
  contactPerson String?
  clientType     String   // e.g., 'Customer', 'Supplier'
  creditLimit Int?     // Optional credit limit for the client
  address String?
  place String?
  stateCode String?
  pincode String?
  billingAddress String?
  shippingAddress String?
  shippingGstin String?
  shippingState String?
  shippingStateCode String?
  shippingPincode String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, gstin])
  @@unique([userId, phoneNumber])
  @@unique([userId, email])
  @@index([userId])
}

model Invoices {
  id          Int      @id @default(autoincrement())
  userId      String
  invoiceNumber String
  invoiceDate DateTime
  dueDate     DateTime
  documentTypeCode String @default("INV")
  documentDate DateTime?
  precedingInvoiceReference String?
  precedingInvoiceDate DateTime?
  invoiceType String   // e.g., 'Sales', 'Purchase'
  supplyTypeCode String?
  isService String?
  supplierLegalName String?
  supplierAddress String?
  supplierPlace String?
  supplierStateCode String?
  supplierPincode String?
  party String   // Client or Supplier name
  partyGstin String
  recipientLegalName String?
  recipientAddress String?
  recipientStateCode String?
  placeOfSupplyStateCode String?
  recipientPincode String?
  recipientPlace String?
  irn String?
  shippingToGstin String?
  shippingToState String?
  shippingToStateCode String?
  shippingToPincode String?
  dispatchFromName String?
  dispatchFromAddress String?
  dispatchFromPlace String?
  dispatchFromPincode String?
  items Json?
  assessableValue String?
  gstRate String?
  igstValue String?
  cgstValue String?
  sgstValue String?
  amount String?
  ewayBillNumber String?
  transportMode String?
  notes String?
  gst String?
  totalAmount String?
  status String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, invoiceDate])
}

model Expenses {
  id          Int      @id @default(autoincrement())
  userId      String
  title String
  category       String
  amount String
  gst String
  totalAmount String?
  vendor String?
  paymentMode String
  date DateTime
  notes String?
  uploadReceipt String?
  itc String?
  status String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([userId, date])
}

model Transactions {
  id          Int      @id @default(autoincrement())
  userId      String
  transactionType String
  mode       String
  amount String
  date DateTime
  description String
  reference Int?     // Optional reference for the transaction
  category String?
  notes String?
  status String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
}

model Settings {
  id          Int      @id @default(autoincrement())
  userId      String   @unique
  companyName String?
  pan         String?
  gstin       String?
  address     String?
  phone       String?
  email       String?
  bankName    String?
  accountNumber String?
  ifsc        String?
  branch      String?
  logoUrl     String?
  invoicePrefix String?
  dueDays     Int?     @default(30)
  defaultDocumentTypeCode String? @default("INV")
  defaultSupplyTypeCode String? @default("B2B")
  defaultIsService String? @default("N")
  supplierLegalName String?
  supplierAddress String?
  supplierPlace String?
  supplierStateCode String?
  supplierPincode String?
  dispatchFromName String?
  dispatchFromAddress String?
  dispatchFromPlace String?
  dispatchFromPincode String?
  invoiceFooter String?
  invoiceTemplate String? @default("standard")
  einvoiceEnabled Boolean? @default(false)
  termsConditions String @default("1. Goods once sold will not be taken back.\n2. Interest @ 18% p.a. may be charged on delayed payment.\n3. Subject to local jurisdiction only.")
  gstr1Alerts Boolean? @default(true)
  gstr3bAlerts Boolean? @default(true)
  paymentDueAlerts Boolean? @default(true)
  remindBeforeDays Int? @default(3)
  emailNotifications Boolean? @default(true)
  smsNotifications Boolean? @default(false)
  whatsappNotifications Boolean? @default(false)
  notificationEmail String?
  notificationPhone String?
  theme           String? @default("light")
  compactMode     Boolean? @default(false)
  accentColor     String? @default("#2563eb")
  dateFormat      String? @default("DD/MM/YYYY")
  currencyFormat  String? @default("INR")
  numberFormat    String? @default("indian")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GSTFiling {
  id              Int      @id @default(autoincrement())
  userId          String
  filingPeriod    String   // e.g., "2024-01", "Q1-2024"
  filingType      GstFilingType
  status          GstFilingStatus @default(draft) // draft, filed, submitted
  totalSales      Decimal  @default(0) @db.Decimal(15, 2)
  totalPurchases  Decimal  @default(0) @db.Decimal(15, 2)
  igst            Decimal  @default(0) @db.Decimal(15, 2)
  cgst            Decimal  @default(0) @db.Decimal(15, 2)
  sgst            Decimal  @default(0) @db.Decimal(15, 2)
  cess            Decimal  @default(0) @db.Decimal(15, 2)
  itcAvailable    Decimal  @default(0) @db.Decimal(15, 2)
  taxLiability    Decimal  @default(0) @db.Decimal(15, 2)
  taxPaid         Decimal  @default(0) @db.Decimal(15, 2)
  filedDate       DateTime?
  dueDate         DateTime
  arn             String?  // Acknowledgement Reference Number
  calculationData Json?    // Store detailed calculation breakdown
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([userId, filingPeriod, filingType])
  @@index([userId, filingPeriod])
  @@index([userId, status])
  @@index([userId, dueDate])
}

model GSTPayment {
  id              Int      @id @default(autoincrement())
  userId          String
  filingId        Int
  amount          Decimal  @db.Decimal(15, 2)
  status          GstPaymentStatus @default(pending)
  paymentDate     DateTime?
  reference       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, filingId])
  @@index([status])
}

model Report {
  id          Int      @id @default(autoincrement())
  userId      String
  reportType  String   // sales, purchase, gst, profit-loss, etc.
  reportName  String
  period      String   // month, quarter, year
  startDate   DateTime
  endDate     DateTime
  data        Json     // Store report data as JSON
  generatedAt DateTime @default(now())
  parameters  Json?    // Store filters/parameters used
  
  @@index([userId, reportType, startDate])
}

model DashboardStats {
  id              Int      @id @default(autoincrement())
  userId          String   @unique
  totalRevenue    Decimal  @default(0) @db.Decimal(15, 2)
  totalExpenses   Decimal  @default(0) @db.Decimal(15, 2)
  pendingInvoices Int      @default(0)
  overdueInvoices Int      @default(0)
  totalClients    Int      @default(0)
  gstLiability    Decimal  @default(0) @db.Decimal(15, 2)
  monthlyRevenue  Json?    // Store monthly revenue data
  categoryExpenses Json?   // Store expense breakdown
  lastUpdated     DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
