# Database
# Example (Neon pooler):
# DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST:5432/DB_NAME?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require&connect_timeout=15"

# CORS
CORS_ORIGIN=http://localhost:3000

# Reminder email delivery (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart GST <your-email@example.com>"

# OCR (Invoice upload)
# Primary high-accuracy engine: Google Vision DOCUMENT_TEXT_DETECTION
# If this key is missing, backend falls back to Tesseract OCR.
GOOGLE_CLOUD_VISION_API_KEY=

# Optional OCR fallback via Gemini multimodal API (works for image/PDF too)
GOOGLE_API_KEY=
GEMINI_OCR_MODEL=gemini-2.0-flash

# Razorpay (Subscription payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
